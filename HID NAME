local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local NEW_NAME = "Anouar777xX"  -- TON NOUVEAU NOM

local function FilterString(text)
    return string.gsub(text, LocalPlayer.Name, NEW_NAME)
end

-- Scan initial : tous les textes avec ton nom
for _, obj in pairs(game:GetDescendants()) do
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        obj.Text = FilterString(obj.Text)
    end
end

-- Surveille les nouveaux textes
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        obj:GetPropertyChangedSignal("Text"):Connect(function()
            obj.Text = FilterString(obj.Text)
        end)
    end
end)

-- HOOK ANTI-RESET (c'est ça qui marche !)
if getrawmetatable then
    local mt = getrawmetatable(game)
    local old_newindex = mt.__newindex
    mt.__newindex = function(self, key, value)
        if (self:IsA("TextLabel") or self:IsA("TextButton")) and key == "Text" and type(value) == "string" then
            return old_newindex(self, key, FilterString(value))
        end
        return old_newindex(self, key, value)
    end
end

print("✅ SEULEMENT TON NOM → Anouar777x (nametag + partout) ! Les autres OK 👻 BlockSpin")
