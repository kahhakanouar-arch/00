local Players = game:GetService("Players")
local player = Players.LocalPlayer
local NEW_NAME = "Anouar777x"

local function updateLabel(textLabel)
    local oldText = textLabel.Text
    if string.find(oldText, player.Name) then
        textLabel.Text = string.gsub(oldText, player.Name, NEW_NAME)
    end
end

local function setupGui(gui)
    for _, descendant in pairs(gui:GetDescendants()) do
        if descendant:IsA("TextLabel") then
            updateLabel(descendant)
        end
    end
    gui.DescendantAdded:Connect(function(desc)
        if desc:IsA("TextLabel") then
            desc:GetPropertyChangedSignal("Text"):Connect(updateLabel)
        end
    end)
end

local function onHead(child)
    if child:IsA("BillboardGui") then
        setupGui(child)
    end
end

local function renameNametag(character)
    local head = character:WaitForChild("Head", 10)
    if head then
        for _, child in pairs(head:GetChildren()) do
            onHead(child)
        end
        head.ChildAdded:Connect(onHead)
    end
end

if player.Character then
    renameNametag(player.Character)
end
player.CharacterAdded:Connect(renameNametag)

