local Config = {
    ProtectedName = "Anouar777x",  -- TON NOUVEAU NOM ICI !
    OtherPlayers = false,          -- false = seulement TON nom changé
    OtherPlayersTemplate = "Player",
    RenameTextBoxes = false,       -- Évite bugs GUI
    UseMetatableHook = true,       -- Active pour anti-reset (désactive si bug executor)
    UseAggressiveFiltering = false -- Pas de lag
}

local ProtectedNames = {}
local Counter = 1
if Config.OtherPlayers then
    for _, player in pairs(game:GetService("Players"):GetPlayers()) do
        ProtectedNames[player.Name] = Config.OtherPlayersTemplate .. Counter
        Counter = Counter + 1
    end
    game.Players.PlayerAdded:Connect(function(player)
        ProtectedNames[player.Name] = Config.OtherPlayersTemplate .. Counter
        Counter = Counter + 1
    end)
end

local LPName = game.Players.LocalPlayer.Name
local IsA = game.IsA

local function FilterString(S)
    local RS = S
    if Config.OtherPlayers then
        for realName, fakeName in pairs(ProtectedNames) do
            RS = string.gsub(RS, realName, fakeName)
        end
    end
    return string.gsub(RS, LPName, Config.ProtectedName)
end

-- Scan initial (nametag, leaderboard, chat...)
for _, obj in pairs(game:GetDescendants()) do
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        obj.Text = FilterString(obj.Text)
    end
end

-- Surveille nouveaux textes
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        obj:GetPropertyChangedSignal("Text"):Connect(function()
            obj.Text = FilterString(obj.Text)
        end)
    end
end)

-- Hook pro (anti-reset nametag)
if Config.UseMetatableHook and getrawmetatable then
    local mt = getrawmetatable(game)
    local old = mt.__newindex
    local newindex = function(self, key, value)
        if (self:IsA("TextLabel") or self:IsA("TextButton")) and key == "Text" and type(value) == "string" then
            return old(self, key, FilterString(value))
        end
        return old(self, key, value)
    end
    mt.__newindex = newindex
end

